{
  "name": "mts-alhidayatul",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "serve": "vite preview",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && wrangler pages deploy",
    "preview:cf": "npm run build && wrangler pages dev ./.output/public",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply mts-alhidayatul-db --local",
    "db:migrate": "wrangler d1 migrations apply mts-alhidayatul-db --remote",
    "db:seed:local": "wrangler d1 execute mts-alhidayatul-db --local --file=./drizzle/seed.sql",
    "db:seed": "wrangler d1 execute mts-alhidayatul-db --remote --file=./drizzle/seed.sql"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/react-query": "^5.66.0",
    "drizzle-orm": "^0.38.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "drizzle-kit": "^0.30.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^7.0.0",
    "wrangler": "^3.99.0"
  }
}
